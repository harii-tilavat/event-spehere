# --- Phase 0 (required) ---
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

DB_HOST=localhost
# docker-compose maps the container to host port 3307 (3306 may be taken by a system MySQL)
DB_PORT=3307
DB_NAME=eventsphere
DB_USER=root
DB_PASSWORD=eventsphere_dev

# --- Phase 1: auth ---
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

# --- Phase 2: uploads ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Phase 1: email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="EventSphere <no-reply@eventsphere.app>"

# --- Phase 4: payments ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Phase 5: tickets ---
QR_TICKET_SECRET=
